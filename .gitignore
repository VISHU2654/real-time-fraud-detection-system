# =============================================================================
# Real-Time Fraud Detection System — .gitignore
# =============================================================================

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Build output ---
build/
dist/

# --- Environment & Secrets ---
.env
.env.*
!.env.example

# --- Datasets (use download script instead of committing to Git) ---
datasets/*.csv

# --- ML Model Artifacts (use model registry) ---
models/*.onnx
models/*.onnx.data

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
*.egg
venv/
.venv/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Logs ---
*.log
logs/

# --- Test Coverage ---
coverage/
.nyc_output/

# --- Docker ---
docker-compose.override.yml