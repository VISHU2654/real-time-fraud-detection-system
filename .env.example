# =============================================================================
# Real-Time Fraud Detection System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the .env file to version control.
# =============================================================================

# --- API Server ---
API_PORT=4000
JWT_SECRET=CHANGE_ME_to_a_secure_random_string_at_least_32_chars
ADMIN_USERNAME=admin
# Generate with: node -e "const bcrypt = require('bcrypt'); bcrypt.hash('your-password', 12).then(h => console.log(h))"
ADMIN_PASSWORD_HASH=$2b$10$q5hlxRRXpEztcUbwRkCw1Or3SWyOAyYM28aK9q0ZX8Lc/xDY744Au

# --- MongoDB ---
MONGO_URI=mongodb://mongodb:27017/fraudDB

# --- Kafka ---
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=transactions

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- Kafka Consumer ---
CONSUMER_PORT=4001
KAFKA_GROUP_ID=fraud-detector-group
MAX_CACHE_SIZE=50
DEFAULT_FRAUD_THRESHOLD=0.60

# --- Analyst Console ---
REACT_APP_API_URL=http://localhost:4000

# --- Logging ---
LOG_LEVEL=info
NODE_ENV=development
